# ============================================================================
# CUGAAgent Demo Apps — shared environment file
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#   python3 launch.py          # starts all apps with these env vars
#
# All apps inherit every variable below. App-specific variables only apply
# to the apps that read them — unused variables are silently ignored.
# ============================================================================


# ── LLM provider ─────────────────────────────────────────────────────────────
# Used by: all apps
# Options: rits | watsonx | anthropic | openai | ollama | litellm
LLM_PROVIDER=rits

# Override the default model for the chosen provider (optional)
LLM_MODEL=gpt-oss-120b


# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used by: all apps (when LLM_PROVIDER=anthropic)
# Default model: claude-3-5-sonnet-20241022
# Sign up: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── RITS (IBM Research Inference-to-Service) ──────────────────────────────────
# Used by: all apps (when LLM_PROVIDER=rits)
# Default model: llama-3-3-70b-instruct
# Other models:  gpt-oss-120b | qwen3-5-397b-a17b-fp8 | mistral-large-3-675b-2512-fp4
RITS_API_KEY=RITS_API_KEY=<>
RITS_BASE_URL=https://inference-3scale-apicast-production.apps.rits.fmaas.res.ibm.com


# ── watsonx.ai ────────────────────────────────────────────────────────────────
# Used by: all apps (when LLM_PROVIDER=watsonx)
# Default model: meta-llama/llama-3-3-70b-instruct
# WATSONX_APIKEY=your_watsonx_api_key_here
# WATSONX_PROJECT_ID=your_project_id_here   # one of project_id or space_id required
# WATSONX_SPACE_ID=your_space_id_here
# WATSONX_URL=https://us-south.ml.cloud.ibm.com


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used by: all apps (when LLM_PROVIDER=openai)
# Default model: gpt-4o
# OPENAI_API_KEY=your_openai_api_key_here


# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# Used by: all apps (when LLM_PROVIDER=ollama)
# Default model: llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434


# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
# Used by: all apps (when LLM_PROVIDER=litellm)
# Default model: GCP/gemini-2.0-flash
# LITELLM_API_KEY=your_litellm_api_key_here
# LITELLM_BASE_URL=https://your-litellm-proxy/


# ── Web search (Tavily) ───────────────────────────────────────────────────────
# Used by: web_researcher, travel_planner
# Sign up: https://tavily.com
TAVILY_API_KEY=<>


# ── Stock data (Alpha Vantage) ────────────────────────────────────────────────
# Used by: stock_alert
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=<>


# ── Travel data (OpenTripMap) ─────────────────────────────────────────────────
# Used by: travel_planner
# Free tier, 500 req/day. Sign up: https://opentripmap.io/product
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here


# ── Email / SMTP (optional — apps fall back to server log if not set) ─────────
# Used by: newsletter, drop_summarizer, smart_todo, stock_alert, web_researcher
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=<>
SMTP_PASSWORD=<>

# Recipient addresses (each app has its own variable)
ALERT_TO=<>      # newsletter, drop_summarizer, stock_alert
DIGEST_TO=<>      # smart_todo
RESEARCH_TO=<>   # web_researcher


# ── Voice / Whisper ───────────────────────────────────────────────────────────
# Used by: voice_journal
# Model size: tiny | base | small | medium | large  (default: base)
# WHISPER_MODEL=base


# ── Server monitor thresholds (optional — sensible defaults built in) ─────────
# Used by: server_monitor
# CPU_THRESHOLD=75        # warn %
# CPU_CRITICAL=90         # critical %
# RAM_THRESHOLD=80
# RAM_CRITICAL=92
# DISK_THRESHOLD=80
# DISK_CRITICAL=90
# POLL_INTERVAL_SECONDS=60
# ALERT_COOLDOWN_SECONDS=900


# ── Drop summarizer watch directory (optional) ────────────────────────────────
# Used by: drop_summarizer
# WATCH_DIR=/path/to/your/inbox
# POLL_SECONDS=15


# ── No key needed ─────────────────────────────────────────────────────────────
# Wikipedia REST API  — https://en.wikipedia.org/api/rest_v1/
# wttr.in weather     — https://wttr.in/:help
# Nominatim geocoding — https://nominatim.openstreetmap.org/
