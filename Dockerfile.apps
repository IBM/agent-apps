# syntax=docker/dockerfile:1
# ============================================================
# Dockerfile.apps — shared base image for all cuga demo apps.
#
# Build:
#   docker compose build
# ============================================================
FROM python:3.13-slim

# System deps:
#   ffmpeg       — required by faster-whisper for video files
#   libgomp1     — runtime lib for faster-whisper (OpenMP)
#   build-essential — compiling some Python C extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        libgomp1 \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements first so Docker can cache this layer
COPY requirements.apps.txt .

RUN pip install --no-cache-dir -r requirements.apps.txt

# Pre-download the whisper tiny model so the first transcription doesn't stall
# on a cold HuggingFace download inside the container.
RUN python -c "from faster_whisper import WhisperModel; WhisperModel('tiny', compute_type='int8')"

# Copy the full apps directory (shared helpers _llm.py, _image_utils.py + all app dirs)
COPY apps/ ./apps/

COPY start.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]
